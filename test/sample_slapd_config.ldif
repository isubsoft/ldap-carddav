# Specifying limits assuming mdb database index is 1
dn: olcDatabase={1}mdb,cn=config
changetype: modify
add: olcLimits
olcLimits: dn.exact="cn=carddavsync,ou=People,dc=example,dc=org" size=unlimited time=unlimited
-
# Allow carddav sync user to read few attributes
add: olcAccess
olcAccess: 
 to 
 dn.subtree="ou=People,dc=example,dc=org" 
 attrs=entry,
 entryUUID,
 modifyTimestamp 
 by 
 dn.exact="cn=carddavsync,ou=People,dc=example,dc=org" 
 read 
 by 
 * 
 none 
 break
